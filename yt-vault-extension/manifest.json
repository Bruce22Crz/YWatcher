{
  "manifest_version": 3,
  "name": "YouTube Vault — трекер просмотра",
  "version": "1.1",
  "description": "Показывает прогресс просмотра YouTube-видео прямо в твоём каталоге videohranilishe.",
  "permissions": ["storage"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "file:///*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["youtube-tracker.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["file:///*"],
      "js": ["catalog-overlay.js"],
      "run_at": "document_idle"
    }
  ]
}
